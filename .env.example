# Puerto del servidor
PORT=4001

# Dirección de escucha (0.0.0.0 para acceso externo, 127.0.0.1 para localhost)
BIND=127.0.0.1

# Telegram (opcional — sin esto no se envían notificaciones)
# Crea un bot con @BotFather y obtén el token
TELEGRAM_BOT_TOKEN=
# ID del chat/grupo donde recibir las notificaciones
TELEGRAM_CHAT_ID=
